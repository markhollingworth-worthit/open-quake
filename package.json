{
  "name": "open-quake",
  "version": "0.2.4",
  "private": true,
  "description": "Open driver + multi-grid touchscreen launcher for the DK-QUAKE / ARIS-68 touchscreen-and-knob macro device.",
  "main": "app/main.js",
  "author": "TeeJS",
  "engines": {
    "node": ">=18 <25"
  },
  "scripts": {
    "postinstall": "patch-package",
    "start": "node build-smtc.js && electron .",
    "rebuild": "electron-rebuild -v 23.0.0 -f",
    "build:smtc": "node build-smtc.js",
    "dist": "node build-smtc.js && electron-builder --win"
  },
  "license": "SEE LICENSE IN LICENSE",
  "keywords": [
    "dk-quake",
    "aris-68",
    "decokee",
    "stream-deck",
    "macropad",
    "node-hid",
    "electron"
  ],
  "dependencies": {
    "node-hid": "^3.3.0",
    "robotjs": "^0.6.0",
    "systeminformation": "^5.31.7"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "electron": "^23.0.0",
    "electron-builder": "^24.13.3",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0"
  },
  "build": {
    "appId": "com.teejs.openquake",
    "productName": "open-quake",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!app/config.json",
      "!docs/**",
      "!tools/**",
      "!native/**",
      "!build-smtc.js",
      "!sign.js",
      "!afterpack.js",
      "!.signing/**"
    ],
    "npmRebuild": false,
    "afterPack": "./afterpack.js",
    "asarUnpack": [
      "apps/**/*",
      "app/native/**",
      "**/*.node"
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "app/icon.png",
      "sign": "./sign.js"
    },
    "portable": {
      "artifactName": "open-quake-${version}-portable.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "artifactName": "open-quake-${version}-setup.${ext}"
    }
  }
}
