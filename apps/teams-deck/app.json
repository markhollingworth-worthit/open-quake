{
  "id": "teams-deck",
  "name": "Teams Deck",
  "entry": "index.html",
  "served": true,
  "hideGridInEditor": true,
  "options": [
    {
      "key": "shortcutProfile",
      "label": "Shortcuts",
      "type": "select",
      "default": "desktop",
      "choices": [
        ["desktop", "Desktop app"],
        ["web", "Website"]
      ]
    },
    {
      "key": "statusText",
      "label": "Status text",
      "type": "text",
      "default": "Teams status: placeholder"
    },
    {
      "key": "nextMeetingText",
      "label": "Next meeting",
      "type": "text",
      "default": "Next meeting: placeholder"
    },
    {
      "key": "graphToken",
      "label": "Microsoft Graph token",
      "type": "secret",
      "default": "",
      "help": "Optional. Requires Presence.Read for status/call state and Calendars.Read for next meeting."
    }
  ],
  "grid": {
    "cols": 9,
    "rows": 3,
    "profileOption": "shortcutProfile",
    "defaults": [
      { "label": "Teams App", "icon": "🪟", "type": "url", "value": "msteams://" },
      { "label": "Activity", "icon": "🔔", "type": "key", "value": "ctrl+1", "focusUrl": "msteams://" },
