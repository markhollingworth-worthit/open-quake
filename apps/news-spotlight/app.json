{
  "id": "news-spotlight",
  "name": "News Spotlight",
  "entry": "index.html",
  "served": true,
  "server": "server.js",
  "hideGridInEditor": true,
  "proxy": {
    "methods": ["GET"],
    "verifySslOption": "verifySsl",
    "allow": [
      {
        "pattern": "^https?:\\/\\/(?!(?:localhost|127(?:\\.\\d{1,3}){3}|10(?:\\.\\d{1,3}){3}|192\\.168(?:\\.\\d{1,3}){2}|172\\.(?:1[6-9]|2\\d|3[0-1])(?:\\.\\d{1,3}){2}|\\[::1\\]))[^\\s]+$"
      }
    ]
  },
  "options": [
    {
      "key": "feeds",
      "label": "RSS feeds JSON",
      "type": "text",
      "default": "[{\"id\":\"bbc\",\"name\":\"BBC News\",\"url\":\"https://feeds.bbci.co.uk/news/rss.xml\",\"category\":\"World\",\"priority\":1,\"enabled\":true,\"includeInRotation\":true,\"defaultImage\":\"\"},{\"id\":\"sky\",\"name\":\"Sky News\",\"url\":\"https://feeds.skynews.com/feeds/rss/home.xml\",\"category\":\"Top Stories\",\"priority\":2,\"enabled\":true,\"includeInRotation\":true,\"defaultImage\":\"\"},{\"id\":\"verge\",\"name\":\"The Verge\",\"url\":\"https://www.theverge.com/rss/index.xml\",\"category\":\"Technology\",\"priority\":3,\"enabled\":true,\"includeInRotation\":true,\"defaultImage\":\"\"},{\"id\":\"ars\",\"name\":\"Ars Technica\",\"url\":\"https://feeds.arstechnica.com/arstechnica/index\",\"category\":\"Technology\",\"priority\":4,\"enabled\":true,\"includeInRotation\":true,\"defaultImage\":\"\"}]",
      "help": "JSON array of RSS feed objects. Each feed supports id, name, url, category, priority, enabled, includeInRotation, maxItems, and defaultImage."
    },
    {
      "key": "storyDuration",
      "label": "Story duration",
      "type": "select",
      "default": "15",
      "choices": [
        ["10", "10 seconds"],
        ["15", "15 seconds"],
        ["20", "20 seconds"],
        ["30", "30 seconds"],
        ["60", "60 seconds"]
      ]
    },
    {
      "key": "showSummary",
      "label": "Show summary",
      "type": "bool",
      "default": true
    },
    {
      "key": "showPublishedTime",
      "label": "Show published time",
      "type": "bool",
      "default": true
    },
    {
      "key": "showCategory",
      "label": "Show category",
      "type": "bool",
      "default": true
    },
    {
      "key": "showStoryCounter",
      "label": "Show story counter",
      "type": "bool",
      "default": true
    },
    {
      "key": "enableKenBurns",
      "label": "Ken Burns motion",
      "type": "bool",
      "default": false
    },
    {
      "key": "enableBreakingNews",
      "label": "Breaking news mode",
      "type": "bool",
      "default": true
    },
    {
      "key": "refreshIntervalMinutes",
      "label": "Refresh minutes",
      "type": "text",
      "default": "15"
    },
    {
      "key": "verifySsl",
      "label": "Verify SSL",
      "type": "bool",
      "default": true
    }
  ]
}
