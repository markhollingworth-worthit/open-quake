[
  {
    "id": "clock",
    "name": "Flip Clock",
    "file": "clock.html",
    "options": [
      { "key": "mode",    "label": "Mode",          "type": "select", "default": "24",   "choices": [["24", "24-hour"], ["12", "12-hour"]] },
      { "key": "theme",   "label": "Theme",         "type": "select", "default": "dark", "choices": [["dark", "Dark"], ["classic", "Classic"]] },
      { "key": "seconds", "label": "Show seconds",  "type": "bool",   "default": false },
      { "key": "date",    "label": "Show date & day", "type": "bool", "default": true }
    ]
  },
  {
    "id": "music",
    "name": "Music",
    "file": "musicview.html",
    "served": true,
    "options": [],
    "grid": {
      "cols": 2,
      "rows": 2,
      "defaults": [
        { "label": "Spotify",     "icon": "🎵", "type": "url", "value": "https://open.spotify.com" },
        { "label": "YT Music",    "icon": "📺", "type": "url", "value": "https://music.youtube.com" },
        { "label": "Apple Music", "icon": "🍎", "type": "url", "value": "https://music.apple.com" },
        { "label": "Tidal",       "icon": "🌊", "type": "url", "value": "https://listen.tidal.com" }
      ]
    }
  },
  {
    "id": "chat",
    "name": "Open WebUI",
    "file": "chatview.html",
    "served": true,
    "options": [
      { "key": "endpoint", "label": "Open WebUI chat URL (…/api/chat/completions)", "type": "text", "default": "" },
      { "key": "api_key",  "label": "API key",                                       "type": "secret", "default": "", "help": "In Open WebUI: avatar (bottom-left) → Settings → Account → API Keys → Create new secret key (an admin may need to enable API keys first)." },
      { "key": "model",    "label": "Model (required, e.g. llama3.2)",               "type": "text", "default": "" }
    ]
  },
  {
    "id": "openaiusagepop",
    "name": "OpenAI Usage Pulse",
    "file": "openaiusage.pop.html",
    "served": true,
    "options": [
      { "key": "api_key", "label": "OpenAI API key", "type": "secret", "default": "" },
      { "key": "org", "label": "Organization ID", "type": "text", "default": "" },
      { "key": "project", "label": "Project ID", "type": "text", "default": "" },
      { "key": "days", "label": "Window (days)", "type": "select", "default": "7", "choices": [["1", "1"], ["7", "7"], ["30", "30"], ["90", "90"]] },
      { "key": "autorefresh", "label": "Auto refresh", "type": "bool", "default": true },
      { "key": "refreshSecs", "label": "Refresh", "type": "select", "default": "60", "choices": [["30", "30 seconds"], ["60", "1 minute"], ["120", "2 minutes"], ["300", "5 minutes"]] }
    ]
  },
  {
    "id": "worldcuptracker",
    "name": "FIFA World Cup Tracker",
    "file": "worldcup.tracker.html",
    "served": true,
    "options": [
      { "key": "year", "label": "Tournament", "type": "select", "default": "2026", "choices": [["2026", "2026"], ["2022", "2022"], ["2018", "2018"], ["2014", "2014"]] },
      { "key": "api_key", "label": "API-Football key", "type": "secret", "default": "" },
      { "key": "focus_team", "label": "Focus team (optional)", "type": "text", "default": "" },
      { "key": "show_completed", "label": "Show completed matches", "type": "bool", "default": true },
      { "key": "refresh", "label": "Refresh", "type": "select", "default": "60", "choices": [["30", "30 seconds"], ["60", "1 minute"], ["120", "2 minutes"], ["300", "5 minutes"], ["900", "15 minutes"]] }
    ]
  }
]
