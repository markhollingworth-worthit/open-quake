diff --git a/node_modules/robotjs/src/mouse.c b/node_modules/robotjs/src/mouse.c
--- a/node_modules/robotjs/src/mouse.c
+++ b/node_modules/robotjs/src/mouse.c
@@ -342,6 +342,9 @@
 	mouseScrollInputs[1].mi.dwExtraInfo = 0;
 	mouseScrollInputs[1].mi.mouseData = y;

-	SendInput(2, mouseScrollInputs, sizeof(mouseScrollInputs));
